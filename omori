from cmu_graphics import *
import time, json, os

def onAppStart(app):
    app.width = 600
    app.height = 800
    app.colors = ["blue", "red", "green", "hotpink"] #name to laneColors
    app.laneOpacity = [60] * 4
    app.keys = ["d", "f", "j", "k"]
    app.state = "menuMode"
    app.songs = [{"title" : "Final Duet", "url" : "https://lambda.vgmtreasurechest.com/soundtracks/omori-original-soundtrack-2020/iipajvyh/172.%20DUET.mp3", "duration": 186},
                {"title" : "My Time", "url" : "https://lambda.vgmtreasurechest.com/soundtracks/omori-original-soundtrack-2020/jzttppiv/178.%20My%20Time.mp3", "duration": 212}
                ]
    app.selectedSong = 0
    app.selectedMode = 0
    app.playOrMap = None
    app.choosingSong = True
    app.song = None
    #add the songs "Title", and "My Time"
    
    # the following are variables for the editor specifically
    app.laneX = [30, 170, 310, 450]
    app.laneWidth = 120
    app.pixelsPerSecond = 300 #scroll speed
    app.editorHitLine = 750 # y of hit line for the editor
    app.editorBottomY = 760 # bottom for editor
    app.editorTime = 0.0
    app.pausedAt = 0.0 #time song was paused at
    app.paused = True
    app.playStartWallTime = 0.0
    app.notes = [] # time and placement for notes for songs
    app.heldKeys = {} #when holding key in edit mode
    #the following are for when playing the game
    app.songStartTime = 0.0
    
def redrawAll(app):
    if app.state == "menuMode":
        drawMenu(app)
    if app.state == "songMenuMode":
        drawSongMenu(app)
    if app.state == "songMode":
        drawSongMode(app)
    if app.state == "editMode":
        drawEditor(app)

def drawMenu(app):
    #REMEMBER want to make this screen much better with the omori light bulb and for it to blink
    rectX = app.width / 2
    rectY = app.height / 2 - 100
    drawLabel("Omori", app.width / 2, 100, size = 25)
    drawLabel("Rhythm Game", app.width / 2, 130, size = 15)
    drawLabel("\u2191 \u2193 to select    ENTER to confirm", rectX, rectY - 100)
    drawLabel("Play", rectX, rectY, size = 25)
    drawRect(rectX, rectY, 200, 100, align = "center", border = "black", borderWidth = 5, fill = None)

def drawLanes(app):
    length = app.width / 5
    height = 20
    y = 750
    x= 30
    for i in range(len(app.colors)):
        drawRect(x, y, length, height, fill = app.colors[i], opacity = app.laneOpacity[i],)
        x += length + 20 #gap between rectangles

def drawSongMode(app):
    drawRect(0, 0, app.width, app.height)  # black background
    now = time.time() - app.songStartTime
    drawLine(0, app.editorHitLine, app.width, app.editorHitLine, fill="white", lineWidth=2) #hit line
    # draw lanes
    for i in range(len(app.laneX)):
        drawRect(app.laneX[i], app.editorHitLine, app.laneWidth, 20, fill=app.colors[i], opacity=app.laneOpacity[i])
    # draw notes
    for note in app.notes:
        x = app.laneX[note["lane"]]
        y = noteY(app, app.editorHitLine, note["time"], now)
        if 0 <= y <= app.height:
            if note.get("endTime") is None:
                drawRect(x, y, app.laneWidth, 10, fill=app.colors[note["lane"]])
            else:
                yEnd = noteY(app, app.editorHitLine, note["endTime"], now)
                drawRect(x, yEnd, app.laneWidth, y - yEnd, fill=app.colors[note["lane"]], opacity=70)

def drawSongMenu(app):
    drawLabel("Select a song with (up) and (down)", 100, 100, size = 20, align = "left")
    rectWidth = 400
    rectHeight = 100
    rectX = 250
    rectY = 180
    edgeOfRect = rectX + (rectWidth // 2)
    topOfRect = rectY - (rectHeight // 2)
    playAndMapcX = edgeOfRect+50
    for i in range(len(app.songs)):
        topOfRect = rectY - (rectHeight // 2)
        playcY = topOfRect + 1/4 * rectHeight
        mapcY = topOfRect + 3/4 * rectHeight
        
        borderColor = "gray" if app.selectedSong == i else "black"
        if app.selectedSong == i and not app.choosingSong:
            playBorder = "green" if app.selectedMode == 0 else "black"
            mapBorder = "green" if app.selectedMode == 1 else "black"
        else:
            playBorder, mapBorder = "black", "black"
        drawLabel(f"{app.songs[i]['title']}", rectX, rectY, size = 20)
        drawRect(rectX, rectY, rectWidth, rectHeight, align = "center", border = borderColor, borderWidth = 5, fill = None)
        drawLabel("Play", playAndMapcX, playcY)
        drawRect(playAndMapcX, playcY, 100, rectHeight / 2, border = playBorder, borderWidth = 5, fill = None, align = "center")
        drawLabel("Map", playAndMapcX, mapcY)
        drawRect(playAndMapcX, mapcY, 100, rectHeight / 2, border = mapBorder, borderWidth = 5, fill = None, align = "center")
        rectY += 120

def drawEditor(app):
    #sigh this pains me
    drawRect(0,0,app.width, app.height)
    drawLanes(app)
    drawLine(0, app.editorHitLine, app.width, app.editorHitLine, fill = "white", lineWidth = 2)
    now = currentTime(app)

    # only calculate beats visible on screen
    startT = now - (app.height - app.editorHitLine) / app.pixelsPerSecond
    endT = now + app.editorHitLine / app.pixelsPerSecond
    startBeat = max(0, int(startT * 4))
    endBeat = int(endT * 4) + 1

    for beat in range(startBeat, endBeat): #grid lines every 0.25 seconds
        #beat grid, every 0.25 seconds
        t = beat * 0.25
        y = noteY(app, app.editorHitLine, t, now)
        op = 20 if beat % 2 == 0 else 0
        drawLine(60, y, app.width - 60, y, fill = "white", opacity = op, lineWidth = 1)
    for note in app.notes: #actually drawing the notes!
        x = app.laneX[note["lane"]]
        y = noteY(app, app.editorHitLine, note["time"], now)
        if note.get("endTime") is None:
            drawRect(x, y, app.laneWidth, 10, fill=app.colors[note["lane"]])
        else:
            yEnd = noteY(app, app.editorHitLine, note["endTime"], now)
            drawRect(x, yEnd, app.laneWidth, y - yEnd, fill=app.colors[note["lane"]], opacity=70)

    for i, startTime in app.heldKeys.items():
        now2 = currentTime(app)
        x = app.laneX[i]
        yStart = noteY(app, app.editorHitLine, startTime, now)
        yEnd = noteY(app, app.editorHitLine, now2, now)
        if yStart - yEnd > 0:
            drawRect(x, yEnd, app.laneWidth, yStart - yEnd, fill=app.colors[i], opacity=50)
        
def togglePlayPause(app):
    if app.paused:
        app.playStartWallTime = time.time()
        app.paused = False
        app.song.play(restart = False)
    else:
        app.pausedAt = currentTime(app)
        app.paused = True
        app.song.pause()
#
def noteY(app, hitY, noteTime, nowTime): #THE MOST IMPORTANT FUNCTION!!!, turns time to a y 
    return hitY - (noteTime - nowTime) * app.pixelsPerSecond #hitY is the line, if noteTime > now its in the future, noteTime < now in the past

def currentTime(app):
    if app.song is None: return app.editorTime
    if app.paused: return app.pausedAt
    return app.pausedAt + (time.time() - app.playStartWallTime) #this means the song is playing

def saveChart(app):
    songTitle = app.songs[app.selectedSong]["title"]
    fileName = f"{songTitle}.json"
    with open(fileName, "w") as f:
        json.dump(app.notes, f)
        
def loadChart(app):
    songTitle = app.songs[app.selectedSong]["title"]
    fileName = f"{songTitle}.json"
    if os.path.exists(fileName):
        with open(fileName, "r") as f:
            app.notes = json.load(f)
    else:
        app.notes = []
        
def onKeyPress(app, key):
    if app.state == "songMenuMode":
        if key == "escape":
            if app.choosingSong == True:
                app.state = "menuMode"
            else:
                app.choosingSong = True
        if key == "enter":
            if app.choosingSong:
                app.choosingSong = False
            else:
                if app.selectedMode == 0:
                    app.state = "songMode"
                    app.song = Sound(app.songs[app.selectedSong]["url"])
                    app.song.play(restart = True)
                    app.songStartTime = time.time()
                    loadChart(app)
                else:
                    app.state = "editMode"
                    app.song = Sound(app.songs[app.selectedSong]["url"])
                    app.paused = True
                    app.pausedAt = 0.0
                    loadChart(app)
        if key == "up":
            if app.choosingSong == True:
                app.selectedSong = (app.selectedSong - 1) % len(app.songs)
            else:
                app.selectedMode = (app.selectedMode - 1) % 2
        if key == "down":
            if app.choosingSong == True:
                app.selectedSong = (app.selectedSong + 1) % len(app.songs)
            else:
                app.selectedMode = (app.selectedMode + 1) % 2
    
    elif app.state == "songMode":
        if key == "escape":
            app.state = "songMenuMode"
            app.song.pause()
            app.song = None
        for i in range(len(app.keys)):
            if key == app.keys[i]: app.laneOpacity[i] = 100
            
    elif app.state == "menuMode":
        if key == "enter":
            app.state = "songMenuMode"
        
    elif app.state == "editMode":
        if key == "escape":
            app.state = "songMenuMode"
            app.song.pause()
            app.song = None
        if key == "space":
            togglePlayPause(app)
        if key == "enter":
            saveChart(app)
            app.state = "songMenuMode"
        if key == "left" and app.paused:
            app.pausedAt = max(0, app.pausedAt - 0.25)
        if key == "right" and app.paused:
            app.pausedAt += 0.25
        for i in range(len(app.keys)):
            if key == app.keys[i]:
                app.heldKeys[i] = currentTime(app)

def onKeyRelease(app, key):
    if app.state == "songMode":
        for i in range(len(app.keys)):
            if key == app.keys[i]: app.laneOpacity[i] = 60

    elif app.state == "editMode":
        for i in range(len(app.keys)):
            if key == app.keys[i] and i in app.heldKeys:
                startTime = app.heldKeys[i]
                endTime = currentTime(app)
                duration = endTime - startTime
                if duration < 0.1:  # too short, treat as tap
                    app.notes.append({"time": startTime, "endTime": None, "lane": i})
                else:
                    app.notes.append({"time": startTime, "endTime": endTime, "lane": i})
                del app.heldKeys[i]

def onMousePress(app, mouseX, mouseY, button):
    if button == 2:
        if app.state == "editMode":
            now = currentTime(app)
            for note in app.notes:
                x = app.laneX[note["lane"]]
                y = noteY(app, app.editorHitLine, note["time"], now)
            if x <= mouseX <= x + app.laneWidth and y <= mouseY <= y + 10:
                app.notes.remove(note)
                return
                
    elif button == 0:
        if app.state == "editMode":
            now = currentTime(app)
            lane = -1
            for i in range(len(app.laneX)):
                if app.laneX[i] <= mouseX <= app.laneX[i] + app.laneWidth:
                    lane = i
            if lane == -1:
                return  # clicked in a gap, do nothing
            noteTime = now + (app.editorHitLine - mouseY) / app.pixelsPerSecond
            app.notes.append({"time": noteTime, "lane": lane})

