def drawEditor(app):
    #sigh this pains me
    drawRect(0,0,app.width, app.height)
    drawLanes(app)
    drawLine(0, app.editorHitLine, app.width, app.editorHitLine, fill = "white", lineWidth = 2)
    now = currentTime(app)

    # only calculate beats visible on screen
    startT = now - (app.height - app.editorHitLine) / app.pixelsPerSecond
    endT = now + app.editorHitLine / app.pixelsPerSecond
    startBeat = max(0, int(startT * 4))
    endBeat = int(endT * 4) + 1

    for beat in range(startBeat, endBeat): #grid lines every 0.25 seconds
        #beat grid, every 0.25 seconds
        t = beat * 0.25
        y = noteY(app, app.editorHitLine, t, now)
        op = 20 if beat % 2 == 0 else 0
        drawLine(60, y, app.width - 60, y, fill = "white", opacity = op, lineWidth = 1)
    for note in app.notes: #actually drawing the notes!
        x = app.laneX[note["lane"]]
        y = noteY(app, app.editorHitLine, note["time"], now)
        if note.get("endTime") is None:
            drawRect(x, y, app.laneWidth, app.noteHeight, fill=app.colors[note["lane"]])
        else:
            yEnd = noteY(app, app.editorHitLine, note["endTime"], now)
            drawRect(x, yEnd, app.laneWidth, y - yEnd, fill=app.colors[note["lane"]], opacity=70)

    for i, startTime in list(app.heldKeys.items()):
        now2 = currentTime(app)
        x = app.laneX[i]
        yStart = noteY(app, app.editorHitLine, startTime, now)
        yEnd = noteY(app, app.editorHitLine, now2, now)
        if yStart - yEnd > 0:
            drawRect(x, yEnd, app.laneWidth, yStart - yEnd, fill=app.colors[i], opacity=50)
        
def togglePlayPause(app):
    if app.paused:
        app.playStartWallTime = time.time()
        app.paused = False
        app.song.play(restart = False)
    else:
        app.pausedAt = currentTime(app)
        app.paused = True
        app.song.pause()
#
def noteY(app, hitY, noteTime, nowTime): #THE MOST IMPORTANT FUNCTION!!!, turns time to a y 
    return hitY - (noteTime - nowTime) * app.pixelsPerSecond #hitY is the line, if noteTime > now its in the future, noteTime < now in the past

def currentTime(app):
    if app.song is None: return app.editorTime
    if app.paused: return app.pausedAt
    return app.pausedAt + (time.time() - app.playStartWallTime) #this means the song is playing

def saveChart(app):
    songTitle = app.songs[app.selectedSong]["title"]
    fileName = f"{songTitle}.json"
    with open(fileName, "w") as f:
        json.dump(app.notes, f)
        
def loadChart(app):
    songTitle = app.songs[app.selectedSong]["title"]
    fileName = f"{songTitle}.json"
    if os.path.exists(fileName):
        with open(fileName, "r") as f:
            app.notes = json.load(f)
        # sanitize notes, needed cuz of frequent crashes
        cleaned = []
        for note in app.notes:
            if "lane" in note and "time" in note:
                if note.get("endTime") is not None:
                    if note["endTime"] <= note["time"]:
                        note["endTime"] = None  # fix bad hold notes
                cleaned.append(note)
        app.notes = cleaned
    else:
        app.notes = []
