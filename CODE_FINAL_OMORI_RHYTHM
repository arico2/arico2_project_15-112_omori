def drawSongMode(app):
    drawRect(0, 0, app.width, app.height)  # black background
    now = time.time() - app.songStartTime
    drawLine(0, app.editorHitLine, app.width, app.editorHitLine, fill="white", lineWidth=2) #hit line
    drawLabel(f"Score: {app.score}", app.width / 2, 60, size=20, fill="white", font = 'OMORI_GAME') #score
    # draw lanes
    for i in range(len(app.laneX)):
        drawRect(app.laneX[i], app.editorHitLine, app.laneWidth, 20, fill=app.colors[i], opacity=app.laneOpacity[i])
    # draw notes
    for note in list(app.notes):
        x = app.laneX[note["lane"]]
        y = noteY(app, app.editorHitLine, note["time"], now)
        if 0 <= y <= app.height:
            if note.get("endTime") is None:
                drawRect(x, y, app.laneWidth, app.noteHeight, fill=app.colors[note["lane"]])
            else:
                yEnd = noteY(app, app.editorHitLine, note["endTime"], now)
                drawRect(x, yEnd, app.laneWidth, y - yEnd, fill=app.colors[note["lane"]], opacity=70)

    if app.judgementTimer > 0: #scoring
        drawLabel(app.judgement, app.width / 2, 400, size=40, fill="white", font = 'OMORI_GAME')
    
    for i, note in list(app.activeHolds.items()): #held down notes
        x = app.laneX[note["lane"]]
        y = noteY(app, app.editorHitLine, note["time"], now)
        yEnd = noteY(app, app.editorHitLine, note["endTime"], now)
        if y - yEnd > 0:
            drawRect(x, yEnd, app.laneWidth, y - yEnd, fill=app.colors[note["lane"]], opacity=40)

    if app.combo > 0:
        drawLabel(f"{app.combo}", app.width / 2, 100, size=app.comboSize, 
                fill=app.comboColor, rotateAngle=app.comboAngle, font = 'OMORI_GAME')

