def getGrade(app):
    total = app.perfects + app.goods + app.misses
    if total == 0: return "?"
    accuracy = (app.perfects + app.goods * 0.5) / total
    if accuracy >= 0.95: return "S"
    elif accuracy >= 0.85: return "A"
    elif accuracy >= 0.70: return "B"
    elif accuracy >= 0.55: return "C"
    elif accuracy >= 0.40: return "D"
    else: return "F"

def onKeyPress(app, key):
    if app.state == "songMenuMode":
        if key == "escape":
            app.clickSound.play(restart=True)
            if app.choosingSong == True:
                app.state = "menuMode"
            else:
                app.choosingSong = True
        if key == "enter":
            app.clickSound.play(restart=True)
            if app.choosingSong:
                app.choosingSong = False
            else:
                app.menuMusic.pause()
                app.menuMusicTimer = 0
                if app.selectedMode == 0:
                    app.state = "songMode"
                    app.song = Sound(app.songs[app.selectedSong]["url"])
                    app.song.play(restart = True)
                    app.songStartTime = time.time()
                    loadChart(app)
                    resetStats(app)
                else:
                    app.state = "editMode"
                    app.song = Sound(app.songs[app.selectedSong]["url"])
                    app.paused = True
                    app.pausedAt = 0.0
                    loadChart(app)
        if key == "up":
            app.clickSound.play(restart=True)
            if app.choosingSong == True:
                app.selectedSong = (app.selectedSong - 1) % len(app.songs)
            else:
                app.selectedMode = (app.selectedMode - 1) % 2
        if key == "down":
            app.clickSound.play(restart=True)
            if app.choosingSong == True:
                app.selectedSong = (app.selectedSong + 1) % len(app.songs)
            else:
                app.selectedMode = (app.selectedMode + 1) % 2
    
    elif app.state == "songMode":
        if key == "escape":
            app.menuMusic.play(restart=True)
            app.menuMusicTimer = 0
            app.state = "songMenuMode"
            try:
                if app.song is not None:
                    app.song.pause()
                    app.song = None
            except: 
                app.song = None

        for i in range(len(app.keys)):
            if key == app.keys[i]:
                app.laneOpacity[i] = 100
                now = time.time() - app.songStartTime
                # tap notes
                for note in list(app.notes):
                    if note["lane"] == i and note.get("endTime") is None:
                        #print("note endTime =", note.get("endTime"), "lane =", note["lane"])
                        diff = abs(note["time"] - now)
                        if diff < 0.08:
                            app.notes.remove(note)
                            app.score += 100
                            app.combo += 1
                            app.perfects += 1
                            app.judgement = "Perfect!"
                            app.judgementTimer = 0.5
                            app.comboSize = min(30 + app.combo // 10, 60)
                            app.comboSize += 5
                            app.comboColor = "yellow" if app.combo >= 100 else "white"
                            break
                        elif diff < 0.15:
                            app.notes.remove(note)
                            app.score += 50
                            app.combo += 1
                            app.goods += 1
                            app.judgement = "Good!"
                            app.judgementTimer = 0.5
                            app.comboSize = min(30 + app.combo // 10, 60)
                            app.comboSize += 5
                            app.comboColor = "yellow" if app.combo >= 100 else "white"
                            break
                # hold notes
                for note in list(app.notes):
                    if note["lane"] == i and note.get("endTime") is not None:
                        diff = abs(note["time"] - now)
                        if diff < 0.3:
                            app.activeHolds[i] = note
                            app.notes.remove(note)
                            break
        if key == "0": #SHORTCUT FUNCTION FOR CONVIENENCE
            app.state = "resultsMode"
            app.song.pause()
            app.song = None
            
    elif app.state == "menuMode":
        if key == "enter":
            app.clickSound.play(restart=True)
            app.state = "songMenuMode"
            app.idleTimer = 0
            app.showSomethingText = False
        
    elif app.state == "editMode":
        if key == "escape":
            app.menuMusic.play(restart=True)
            app.menuMusicTimer = 0
            app.state = "songMenuMode"
            try:
                if app.song is not None:
                    app.song.pause()
                    app.song = None
            except:
                app.song = None
            
            #app.heldKeys = {}
        if key == "space":
            togglePlayPause(app)
        if key == "enter":
            saveChart(app)
            try:
                if app.song is not None:
                    app.song.pause()
                    app.song = None
            except:
                app.song = None
            app.state = "songMenuMode"
        if key == "left" and app.paused:
            app.pausedAt = max(0, app.pausedAt - 0.25)
        if key == "right" and app.paused:
            app.pausedAt += 0.25
        for i in range(len(app.keys)):
            if key == app.keys[i]:
                app.heldKeys[i] = currentTime(app)

    elif app.state == "resultsMode":
        if key == "enter" or key == "escape":
            app.state = "songMenuMode"
            app.menuMusic.play(restart=True)
            app.menuMusicTimer = 0

def resetStats(app):
    app.score = 0
    app.combo = 0
    app.misses = 0
    app.goods = 0
    app.perfects = 0
    app.judgement = ""
    app.judgementTimer = 0
    app.activeHolds = {}
    app.comboSize = 30
    app.comboAngle = 0
    app.comboColor = "white"

def onKeyRelease(app, key):
    if app.state == "songMode": #for holding uses ratio held for that key to determine score lowk personal fav
        for i in range(len(app.keys)):
            if key == app.keys[i]:
                app.laneOpacity[i] = 60
                if i in app.activeHolds:
                    note = app.activeHolds[i]
                    now = time.time() - app.songStartTime
                    holdDuration = note["endTime"] - note["time"]
                    heldFor = now - note["time"]
                    ratio = max(0, min(1, heldFor / holdDuration))
                    if ratio >= 0.9:
                        app.score += 125
                        app.perfects += 1
                        app.judgement = "Perfect!"
                        app.comboSize = min(30 + app.combo // 10, 60)
                        app.comboSize += 5
                        app.comboColor = "yellow" if app.combo >= 100 else "white"
                    elif ratio >= 0.5:
                        app.score += rounded(125 * ratio)
                        app.goods += 1
                        app.judgement = "Good!"
                        app.comboSize = min(30 + app.combo // 10, 60)
                        app.comboSize += 5
                        app.comboColor = "yellow" if app.combo >= 100 else "white"
                    else:
                        app.misses += 1
                        app.judgement = "Miss!"
                        app.combo = 0
                        app.comboAngle = 45
                        app.comboColor = "red"
                        app.comboSize = 30
                    app.combo += 1
                    app.judgementTimer = 0.5
                    del app.activeHolds[i]

    elif app.state == "editMode":
        for i in range(len(app.keys)):
            if key == app.keys[i] and i in app.heldKeys:
                startTime = app.heldKeys.get(i)  # safe get
                if startTime is None:
                    continue
                endTime = currentTime(app)
                duration = endTime - startTime
                if duration < 0.25: #means it is one note only
                    app.notes.append({"time": startTime, "endTime": None, "lane": i})
                else:
                    app.notes.append({"time": startTime, "endTime": endTime, "lane": i})
                app.heldKeys.pop(i, None)  # safe delete



def onMousePress(app, mouseX, mouseY, button):
    if button == 2:
        if app.state == "editMode":
            now = currentTime(app)
            for note in list(app.notes):
                x = app.laneX[note["lane"]]
                y = noteY(app, app.editorHitLine, note["time"], now)
                if x <= mouseX <= x + app.laneWidth and y <= mouseY <= y + 10:
                    app.notes.remove(note)
                    return
                
    elif button == 0:
        if app.state == "editMode":
            now = currentTime(app)
            lane = -1
            for i in range(len(app.laneX)):
                if app.laneX[i] <= mouseX <= app.laneX[i] + app.laneWidth:
                    lane = i
            if lane == -1:
                return  # clicked in a gap, do nothing
            noteTime = now + (app.editorHitLine - mouseY) / app.pixelsPerSecond
            app.notes.append({"time": noteTime, "endTime": None, "lane": lane})

def onStep(app):
    if app.judgementTimer > 0:
        app.judgementTimer -= 0.05
    
    if app.state == "songMode": #user missed notes
        now = time.time() - app.songStartTime
        for note in list(app.notes):
            if now - note["time"] > 0.15:  # note is too far in the past
                if note.get("endTime") is None:  # only miss tap notes this way
                    app.notes.remove(note)
                    app.misses += 1
                    app.combo = 0
                    app.judgement = "Miss!"
                    app.judgementTimer = 0.5
        for i, note in list(app.activeHolds.items()):
            if now - note["endTime"] > 0.15:  # held way too long past end
                holdDuration = note["endTime"] - note["time"]
                heldFor = note["endTime"] - note["time"]  # give full credit since they held past end
                app.score += 125
                app.perfects += 1
                app.judgement = "Perfect!"
                app.judgementTimer = 0.5
                app.combo += 1
                del app.activeHolds[i]
        if app.comboSize > 30:
            app.comboSize -= 1
        if app.comboAngle != 0:
            app.comboAngle *= 0.8

    if app.state == "songMode":
        now = time.time() - app.songStartTime
        if now >= app.songs[app.selectedSong]["duration"]:
            app.state = "resultsMode"
            try:
                if app.song is not None:
                    app.song.pause()
                    app.song = None
            except:
                app.song = None
    
    if app.state in ["menuMode", "songMenuMode"]:
        app.menuMusicTimer += 0.05  # matches judgementTimer speed
        if app.menuMusicTimer >= app.menuMusicDuration:
            app.menuMusicTimer = 0
            app.menuMusic.play(restart=True)
    
    if app.state == "menuMode":
        app.bulbFlicker += 1
        app.idleTimer += 0.05
        if app.bulbFlicker % 5 == 0:  # every 3 steps light flickers
            import random
            app.bulbOpacity = random.randint(20, 100)
        if app.idleTimer >= 5:
            app.showSomethingText = True

def main():
    runApp()

main()
